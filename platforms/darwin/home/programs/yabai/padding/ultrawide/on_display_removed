#!/usr/bin/env bash

#
# Change padding when a display was removed
# Filter out the removed display before checking remaining state
#

source "$HOME/.config/yabai/padding/padding.env"

DISPLAYS=$(yabai -m query --displays)
REMAINING=$(echo "$DISPLAYS" | jq "[.[] | select(.id != $YABAI_DISPLAY_ID)]")
HAS_INTERNAL=$(echo "$REMAINING" | jq -r "[.[].uuid] | any(. == \"$INTERNAL_DISPLAY_UUID\")")
HAS_ULTRAWIDE=$(echo "$REMAINING" | jq -r "[.[].uuid] | any(. == \"$ULTRAWIDE_DISPLAY_UUID\")")

if [ "$HAS_INTERNAL" = "true" ]; then
    "$SET_HORIZONTAL_PADDING" "$PADDING"
elif [ "$HAS_ULTRAWIDE" = "true" ]; then
    "$SET_HORIZONTAL_PADDING" "$ULTRAWIDE_PADDING"
else
    "$SET_HORIZONTAL_PADDING" "$PADDING"
fi
